rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, displayName, email, photoURL, role, createdAt
    //
    // Collection: items
    // Fields: id, title, description, type, category, location, date, imageUrl, reporterUid, status, createdAt
    //
    // Collection: chats
    // Fields: id, participants, itemId, lastMessage, updatedAt
    //
    // Collection: messages (subcollection of chats)
    // Fields: id, chatId, senderUid, text, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.reporterUid;
    }

    function isChatParticipant() {
      return isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "savanakhilrao2006@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    function isValidUser(data) {
      let allowedFields = ['uid', 'displayName', 'email', 'photoURL', 'role', 'createdAt'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000)) &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    function isValidItem(data) {
      let allowedFields = ['id', 'title', 'description', 'type', 'category', 'location', 'date', 'imageUrl', 'reporterUid', 'status', 'createdAt'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(['title', 'type', 'reporterUid', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             data.type in ['lost', 'found'] &&
             (!('category' in data) || (data.category is string && data.category.size() < 100)) &&
             (!('location' in data) || (data.location is string && data.location.size() < 200)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000)) &&
             data.reporterUid == request.auth.uid &&
             data.status in ['active', 'recovered'];
    }

    function isValidChat(data) {
      let allowedFields = ['id', 'participants', 'itemId', 'lastMessage', 'updatedAt'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(['participants', 'itemId']) &&
             data.participants is list && data.participants.size() == 2 &&
             request.auth.uid in data.participants &&
             data.itemId is string;
    }

    function isValidMessage(data) {
      let allowedFields = ['id', 'chatId', 'senderUid', 'text', 'createdAt'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(['chatId', 'senderUid', 'text']) &&
             data.chatId is string &&
             data.senderUid == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000;
    }

    // Test Connection
    match /test/connection {
      allow read: if true;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
    }

    // Items
    match /items/{itemId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidItem(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidItem(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isChatParticipant();
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if isChatParticipant();
    }

    // Messages
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if isAuthenticated() && 
                    request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                    isValidMessage(request.resource.data);
    }
  }
}
